{
	"$schema": "https://raw.githubusercontent.com/atampy25/simple-mod-framework/main/Mod%20Manager/src/lib/manifest-schema.json",
	"version": "0.2.0",
	"id": "Charc0al.NoHoldButtons",
	"name": "No Hold Buttons",
	"description": "Switches out a bunch of long-press button prompts with with normal press",
	"authors": ["Charc0al"],
	"frameworkVersion": "2.33.35",
	"options": [
		{
			"name": "Blend",
			"tooltip": "Blend in",
			"group": "main",
			"type": "checkbox",
			"enabledByDefault": true,
			"contentFolders": ["content/blend"]
		},
		{
			"name": "Card Reader",
			"tooltip": "Card reader",
			"group": "main",
			"type": "checkbox",
			"enabledByDefault": true,
			"contentFolders": ["content/cardreader"]
		},
		{
			"name": "Distractions",
			"tooltip": "Distractions",
			"group": "main",
			"type": "checkbox",
			"enabledByDefault": true,
			"contentFolders": ["content/distraction"]
		},
		{
			"name": "Doors",
			"tooltip": "Unlock doors etc",
			"group": "main",
			"type": "checkbox",
			"enabledByDefault": true,
			"contentFolders": ["content/door"]
		},
		{
			"name": "Freelancer",
			"tooltip": "Misc freelancer stuff",
			"group": "main",
			"type": "checkbox",
			"enabledByDefault": true,
			"contentFolders": ["content/freelancer"]
		},
		{
			"name": "Exits",
			"tooltip": "Exit mission prompts",
			"group": "main",
			"type": "checkbox",
			"enabledByDefault": true,
			"contentFolders": ["content/exit"]
		},
		{
			"name": "Misc",
			"tooltip": "Misc other prompts",
			"group": "main",
			"type": "checkbox",
			"enabledByDefault": true,
			"contentFolders": ["content/misc"]
		}
	],
	"updateCheck": "https://github.com/charc0al/HM3_NoHoldButtons/releases/latest/download/updates.json"
}
